# =============================================================================
# AliceJump 自部署服务 — 环境变量示例
# =============================================================================
# 复制为 .env 并修改:
#   cp deploy/.env.example deploy/.env
# =============================================================================

# 时区
TZ=Asia/Shanghai

# GitHub Token (Shields.io 可选，提高 API 速率限制)
# 创建: https://github.com/settings/tokens/new?scopes=public_repo
# GH_TOKEN=ghp_xxxxxx

# Views Counter 数据库 (默认 SQLite 文件存储)
DB_CONNECTION=sqlite
# 如需 PostgreSQL:
# DB_CONNECTION=pgsql
# DB_HOST=aj-views-counter-db
# DB_PORT=5432
# DB_DATABASE=views_counter
# DB_USERNAME=views_counter
# DB_PASSWORD=change_me
